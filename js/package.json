  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./style.css": "./src/style.css"
  },
  "keywords": [
    "malayalam",
    "stroke-order",
    "handwriting",
    "svg",
    "indic",
    "harfbuzz"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/malayalam-stroker"
  },
  "homepage": "https://github.com/your-username/malayalam-stroker#readme",
  "devDependencies": {},
  "engines": {
    "node": ">=14"
  }
}
