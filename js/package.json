{
  "name": "jayasree",
  "version": "0.3.0",
  "description": "Animated stroke-trace widget for Malayalam (or any script) - renders the JSON produced by the jayasree Python package as a left-to-right ink reveal",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "files": [
    "src/index.js",
    "src/style.css",
    "src/glyph-data.json",
    "src/stroke-data.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./style.css": "./src/style.css"
  },
  "keywords": [
    "malayalam",
    "stroke-order",
    "handwriting",
    "svg",
    "indic",
    "harfbuzz"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sachn1/jayasree"
  },
  "homepage": "https://github.com/sachn1/jayasree#readme",
  "devDependencies": {},
  "engines": {
    "node": ">=14"
  }
}
